    "CarePlan.intent": ["plan", "order"],
    "CarePlan.category": ["us-core assess-plan coding", "SNOMED + Epic urn:oid translation dual coding", "text-only"],
    "CarePlan.activity": ["none (narrative-only plan)", "detail with code+scheduledTiming+performer", "detail with scheduledPeriod+location+CPT/LOINC dual coding", "activity.reference display-only with progress annotation"],
    "CareTeam.status": ["active", "inactive"],
    "CareTeam.participant.role": ["SNOMED + NUCC dual coding with text", "NUCC single coding", "text-only", "code-only coding without display (41672002)"],
    "CareTeam.participant.member": ["Practitioner reference+display", "contained Practitioner (#contained-cdces)", "RelatedPerson reference", "constant patient urn (patient as team member)", "Organization display-only", "PractitionerRole display-rich reference"],
    "Goal.lifecycleStatus": ["active", "completed", "on-hold"],
    "Goal.achievementStatus": ["in-progress", "achieved (coding without text)", "absent"],
    "Goal.description": ["LOINC-coded with text", "text-only", "text-only very long with unicode (饮食目标) and embedded quotes"],
    "Goal.target": ["measure+detailRange+dueDate", "dueDate only (no measure/detail)", "text-only measure + detailString, no due date"],
    "Goal.expressedBy": ["practitioner reference", "patient self (constant urn)", "display-only dietitian"],
    "references": ["constant patient urn everywhere", "display-only contributor/addresses/outcomeReference/managingOrganization", "contained resource", "cross-family CarePlan.goal -> Goal/goal-walking-completed (resolvable within this family)"],
    "quirks": ["Epic proprietary extensions (open.epic.com careplan-episode, team-type; urn:oid goal extension)", "Epic urn:oid identifier and category translation coding", "timezone variety: date-only, Z, -05:00, -06:00"]
  }
