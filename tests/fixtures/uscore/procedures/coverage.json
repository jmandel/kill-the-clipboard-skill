          "procedure-tonsillectomy-childhood-age.json",
          "procedure-cholecystectomy-string.json"
        ],
        "performed[x]": [
          "procedure-colonoscopy-completed.json",
          "procedure-appendectomy-period.json",
          "procedure-dialysis-inprogress.json",
          "procedure-tonsillectomy-childhood-age.json",
          "procedure-cholecystectomy-string.json"
