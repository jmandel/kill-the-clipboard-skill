          "servicerequest-colonoscopy-completed.json",
          "servicerequest-pt-active.json",
          "servicerequest-mri-revoked.json"
        ],
        "requester": [
          "servicerequest-colonoscopy-completed.json",
          "servicerequest-pt-active.json",
          "servicerequest-mri-revoked.json"
        ],
        "reasonCode": [
          "servicerequest-colonoscopy-completed.json",
          "servicerequest-mri-revoked.json"
        ],
        "reasonReference": [
          "servicerequest-pt-active.json"
        ]
      },
      "gaps": [
        "encounter/requester/performer/reasonReference are display-only references rather than resolvable resources (Practitioner/Encounter/Condition fixtures live in their own families)"
      ]
    }
  },
  "variants": {
    "Procedure.status": [
      "completed",
      "in-progress",
      "not-done"
    ],
    "Procedure.performed[x]": [
      "performedDateTime",
      "performedPeriod (start+end)",
      "performedPeriod (start only, in-progress)",
      "performedAge (childhood, UCUM a)",
      "performedString (free-text imprecise date)",
      "absent (not-done)"
    ],
    "Procedure.code coding systems": [
      "CPT + SNOMED dual coding",
      "SNOMED only",
      "code-only coding without display",
      "text-only CodeableConcept"
    ],
    "Procedure.performer": [
      "actor + function + onBehalfOf",
      "actor only",
      "multiple performers"
    ],
    "ServiceRequest.status": [
      "completed",
      "active",
      "revoked"
    ],
    "ServiceRequest.intent": [
      "order",
      "original-order"
    ],
    "ServiceRequest.occurrence[x]": [
      "occurrenceDateTime",
      "occurrenceTiming (boundsPeriod + frequency)",
      "occurrencePeriod"
    ],
    "ServiceRequest.orderDetail": [
      "text-only",
      "CPT-coded"
    ],
    "reason": [
      "reasonCode coded",
      "reasonCode text-only",
      "reasonCode with ICD-10-CM translation",
      "reasonReference display-only"
    ],
    "edgeCases": [
      "very long note text (colonoscopy)",
      "unicode in note (dialysis)",
      "unknown extension noise (dialysis)",
      "Epic-style local identifier oid + local category coding (colonoscopy identifier, MRI category)",
      "reference-by-display-only (encounters, conditions, practitioners)",
      "statusReason on not-done procedure",
      "intra-family basedOn link Procedure -> ServiceRequest",
      "patient-reported history: asserter = constant patient, recorder = practitioner (cholecystectomy, tonsillectomy)",
      "unicode em-dash in performedString (cholecystectomy)"
    ]
  }
}
