{
  "family": "procedures",
  "uscoreVersion": "9.0.0",
  "profiles": {
    "http://hl7.org/fhir/us/core/StructureDefinition/us-core-procedure": {
      "mustSupport": [
        "status",
        "code",
        "subject",
        "performed[x]",
        "encounter"
      ],
      "additionalUscdi": [
        "basedOn",
        "performer",
        "performer.actor",
        "reasonCode",
        "reasonReference"
      ],
