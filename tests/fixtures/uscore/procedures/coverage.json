        "performer.onBehalfOf": [
          "procedure-colonoscopy-completed.json",
          "procedure-appendectomy-period.json"
        ],
        "reasonCode": [
          "procedure-colonoscopy-completed.json",
          "procedure-cardiaccath-notdone.json",
          "procedure-cholecystectomy-string.json"
        ],
        "reasonReference": [
          "procedure-appendectomy-period.json"
        ]
      },
      "gaps": [
        "performedRange not instantiated (no realistic source shape: US exports express imprecision as performedString or performedAge; performedDateTime/Period/String/Age cover four of the five performed[x] arms)",
        "focalDevice not instantiated (SHOULD-level guidance only; implantable-device linkage belongs to the devices family)",
        "encounter is display-only reference, not a resolvable US Core Encounter (encounter family owns Encounter instances)"
      ]
    },
    "http://hl7.org/fhir/us/core/StructureDefinition/us-core-servicerequest": {
      "mustSupport": [
        "status",
        "intent",
        "category",
        "code",
        "subject",
        "encounter",
        "occurrence[x]",
        "authoredOn",
        "requester",
        "reasonCode",
        "reasonReference"
